extends base

block content
  main.main
    .yk-container
      .yk-header
        h1.yk-title My Bookings
        p.yk-subtitle= bookings && bookings.length ? `Manage your upcoming and past bookings (${bookings.length} found)` : 'Explore and book your next adventure'

      if bookings && bookings.length
        .yk-grid
          each b in bookings
            - const startDateStr = b.startDate ? new Date(b.startDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: '2-digit' }) : 'N/A';
            - const endDateStr = b.endDate ? new Date(b.endDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: '2-digit' }) : 'N/A';
            - const statusLabel = (b.status || 'unknown').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
            
            .yk-card
              .yk-card__img-container
                img.yk-card__img(src=`/img/tours/${b.tour ? b.tour.imageCover : 'default.jpg'}`, alt=`${b.tour ? b.tour.name : 'Tour'}`)
                .yk-card__overlay
                  h3.yk-card__title= b.tour ? b.tour.name : 'Tour'
              
              .yk-card__body
                .yk-card__meta-list
                  .yk-card__meta-item
                    span(class=`yk-badge yk-badge--${b.status}`)= statusLabel
                  
                  .yk-card__meta-item
                    svg.yk-card__meta-icon
                      use(xlink:href='/img/icons.svg#icon-calendar')
                    span
                      strong Dates:
                      |  #{startDateStr} — #{endDateStr}
                  
                  .yk-card__meta-item
                    svg.yk-card__meta-icon
                      use(xlink:href='/img/icons.svg#icon-user')
                    span
                      strong Guests:
                      |  #{b.guests || 1} guest(s)
                  
                  .yk-card__meta-item
                    svg.yk-card__meta-icon
                      use(xlink:href='/img/icons.svg#icon-credit-card')
                    span
                      strong Total:
                      |  ₹#{(b.totalPrice || b.price || 0).toLocaleString('en-IN')}
                  
                  if b.guide
                    .yk-card__meta-item
                      svg.yk-card__meta-icon
                        use(xlink:href='/img/icons.svg#icon-user')
                      span
                        strong Guide:
                        |  #{b.guide.name}
                  
                  if b.pickupLocation
                    .yk-card__meta-item
                      svg.yk-card__meta-icon
                        use(xlink:href='/img/icons.svg#icon-map-pin')
                      span
                        strong Pickup:
                        |  #{b.pickupLocation}

              .yk-card__actions
                a.btn.btn--green.btn--small(href=`/booking/${b._id}` style='font-size: 1.2rem; padding: 1rem 2rem;') Details
                if b.tour && b.tour.slug
                  a.btn.btn--white.btn--small(href=`/tour/${b.tour.slug}` style='font-size: 1.2rem; padding: 1rem 2rem;') View Tour
                if b.status !== 'cancelled' && b.status !== 'refunded' && b.status !== 'completed'
                  button.btn.btn--white.btn--small.cancel-booking-btn(data-booking-id=`${b._id}` style='font-size: 1.2rem; padding: 1rem 2rem; color: #e74c3c; border-color: #e74c3c;') Cancel
      else
        .yk-card(style='max-width: 60rem; margin: 4rem auto; padding: 5rem 3rem; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 2rem;')
          div(style='background: rgba(85,197,122,0.1); padding: 2rem; border-radius: 50%;')
            svg(style='width: 6rem; height: 6rem; fill: #55c57a;')
              use(xlink:href='/img/icons.svg#icon-map')
          h2(style='font-size: 2.4rem; font-weight: 700; color: #1e293b; margin: 0;') You have no bookings yet
          p(style='font-size: 1.5rem; color: #64748b; margin: 0;') Start exploring our majestic tours in India and create your first booking!
          a.btn.btn--green(href='/tours' style='margin-top: 1rem;') Browse Tours

  //- Cancel booking handler
  script.
    document.querySelectorAll('.cancel-booking-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const bookingId = this.dataset.bookingId;
        const reason = prompt('Reason for cancellation (optional):');
        if (reason === null) return; // User clicked Cancel on prompt

        this.textContent = 'Cancelling...';
        this.disabled = true;

        try {
          const res = await fetch(`/api/v1/bookings/${bookingId}/cancel`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason })
          });
          const data = await res.json();

          if (!res.ok) throw new Error(data.message || 'Cancellation failed');

          showAlert('success', 'Booking cancelled successfully');
          window.location.reload();
        } catch(err) {
          showAlert('error', `Error: ${err.message}`);
          this.textContent = 'Cancel';
          this.disabled = false;
        }
      });
    });
