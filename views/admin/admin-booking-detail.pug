extends ../base

block content
  main.main
    - const statusColors = { pending_payment: '#ff7730', confirmed: '#55c57a', guide_assigned: '#2998ff', ready_for_trip: '#7c3aed', completed: '#28b487', cancelled: '#e74c3c', refunded: '#f39c12' };
    - const statusLabel = (booking.status || 'unknown').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
    - const allStatuses = ['pending_payment', 'confirmed', 'guide_assigned', 'ready_for_trip', 'completed', 'cancelled', 'refunded'];

    .yk-container
      .yk-header
        h1.yk-title Admin — Booking Detail
        p.yk-subtitle Detailed overview of booking ID: #{booking._id} | Status validation & management panel

      .admin-grid(style='display: grid; grid-template-columns: repeat(auto-fit, minmax(40rem, 1fr)); gap: 3rem;')

        //- Left Column — Booking Info (Styled as yk-card)
        .yk-card
          .yk-card__img-container(style='height: 18rem;')
            if booking.tour
              img.yk-card__img(src=`/img/tours/${booking.tour.imageCover}` alt=`${booking.tour.name}`)
              .yk-card__overlay
                h3.yk-card__title= booking.tour.name
          
          .yk-card__body(style='gap: 2rem;')
            div
              span(class=`yk-badge yk-badge--${booking.status}`)= statusLabel
            
            .yk-card__meta-list(style='font-size: 1.4rem; line-height: 2.2; color: #334155; gap: 1.5rem;')
              p(style='margin: 0;')
                strong User:
                |  #{booking.user ? booking.user.name : 'N/A'} (#{booking.user ? booking.user.email : ''})#{booking.user && booking.user.phone ? ` [📞 ${booking.user.phone}]` : ''}
              p(style='margin: 0;')
                strong Start Date:
                |  #{booking.startDate ? new Date(booking.startDate).toLocaleDateString('en-IN', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) : 'N/A'}
              p(style='margin: 0;')
                strong End Date:
                |  #{booking.endDate ? new Date(booking.endDate).toLocaleDateString('en-IN', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) : 'N/A'}
              p(style='margin: 0;')
                strong Guests:
                |  #{booking.guests || 1} guest(s)
              p(style='margin: 0;')
                strong Price per Person:
                |  ₹#{(booking.price || 0).toLocaleString('en-IN')}
              p(style='font-size: 1.8rem; font-weight: 800; color: #28b487; margin: 1rem 0 0;')
                strong Total:
                |  ₹#{(booking.totalPrice || 0).toLocaleString('en-IN')}
              p(style='margin: 0;')
                strong Payment:
                |  #{booking.paid ? '✅ Paid' : '❌ Unpaid'}
              p(style='margin: 0;')
                strong Payment Status:
                |  #{booking.paymentStatus || 'N/A'}
              if booking.guide
                p(style='margin: 0;')
                  strong Guide:
                  |  #{booking.guide.name} (#{booking.guide.email})#{booking.guide.phone ? ` [📞 ${booking.guide.phone}]` : ''}
              if booking.pickupLocation
                p(style='margin: 0;')
                  strong Pickup Location:
                  |  #{booking.pickupLocation}
              if booking.adminNotes
                p(style='margin: 0; padding: 1rem; background: #f8fafc; border-radius: 8px; border-left: 3px solid #cbd5e1;')
                  strong Internal Admin Notes:
                  br
                  |  #{booking.adminNotes}
              if booking.cancellationReason
                p(style='margin: 0; padding: 1rem; background: rgba(231,76,60,0.05); border-radius: 8px; border-left: 3px solid var(--yk-red); color: var(--yk-red);')
                  strong Cancel Reason:
                  br
                  |  #{booking.cancellationReason}

        //- Right Column — Admin Actions Panel
        .admin-actions-panel(style='display: flex; flex-direction: column; gap: 2.4rem;')

          //- Update Status
          .yk-card
            div(style='padding: 2rem; border-bottom: 1px solid #e2e8f0;')
              h4(style='color: #1e293b; font-family: var(--yk-font-heading); font-size: 1.6rem; font-weight: 700; margin: 0;') Update Status
            div(style='padding: 2rem; display: flex; flex-direction: column; gap: 1.2rem;')
              select#statusSelect(style='width: 100%; padding: 1.2rem; border: 1px solid var(--yk-border-color); border-radius: 8px; font-family: inherit; font-size: 1.4rem; background: #f8fafc;')
                each s in allStatuses
                  - const sl = s.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
                  option(value=s selected=(booking.status === s))= sl
              button.btn.btn--green#updateStatusBtn(data-booking-id=`${booking._id}` style='width: 100%; font-size: 1.3rem; padding: 1.2rem;') Update Status

          //- Assign Guide
          .yk-card
            div(style='padding: 2rem; border-bottom: 1px solid #e2e8f0;')
              h4(style='color: #1e293b; font-family: var(--yk-font-heading); font-size: 1.6rem; font-weight: 700; margin: 0;') Assign Guide
            div(style='padding: 2rem; display: flex; flex-direction: column; gap: 1.2rem;')
              select#guideSelect(style='width: 100%; padding: 1.2rem; border: 1px solid var(--yk-border-color); border-radius: 8px; font-family: inherit; font-size: 1.4rem; background: #f8fafc;')
                option(value='' disabled selected=(!booking.guide)) Select a guide...
                each g in guides
                  option(value=g._id selected=(booking.guide && booking.guide._id && booking.guide._id.toString() === g._id.toString()))
                    | #{g.name} (#{g.role})
              button.btn.btn--green#assignGuideBtn(data-booking-id=`${booking._id}` style='width: 100%; font-size: 1.3rem; padding: 1.2rem;') Assign Guide

          //- Pickup & Notes
          .yk-card
            div(style='padding: 2rem; border-bottom: 1px solid #e2e8f0;')
              h4(style='color: #1e293b; font-family: var(--yk-font-heading); font-size: 1.6rem; font-weight: 700; margin: 0;') Pickup & Notes
            div(style='padding: 2rem; display: flex; flex-direction: column; gap: 1.4rem;')
              div
                label(style='display: block; font-size: 1.15rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 0.6rem;') Pickup Location
                input#pickupInput(type='text' value=(booking.pickupLocation || '') placeholder='e.g., Hotel lobby, 8:00 AM' style='width: 100%; padding: 1.2rem; border: 1px solid var(--yk-border-color); border-radius: 8px; font-family: inherit; font-size: 1.35rem; background: #f8fafc;')
              div
                label(style='display: block; font-size: 1.15rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 0.6rem;') Trip Instructions
                textarea#instructionsInput(rows='2' placeholder='Instructions for the traveler...' style='width: 100%; padding: 1.2rem; border: 1px solid var(--yk-border-color); border-radius: 8px; font-family: inherit; font-size: 1.35rem; background: #f8fafc; resize: vertical;')= booking.tripInstructions || ''
              div
                label(style='display: block; font-size: 1.15rem; color: #64748b; font-weight: 700; text-transform: uppercase; margin-bottom: 0.6rem;') Admin Notes (Internal)
                textarea#notesInput(rows='2' placeholder='Internal notes...' style='width: 100%; padding: 1.2rem; border: 1px solid var(--yk-border-color); border-radius: 8px; font-family: inherit; font-size: 1.35rem; background: #f8fafc; resize: vertical;')= booking.adminNotes || ''
              button.btn.btn--green#updateDetailsBtn(data-booking-id=`${booking._id}` style='width: 100%; font-size: 1.3rem; padding: 1.2rem;') Save Details

          //- Danger Zone
          if booking.status !== 'cancelled' && booking.status !== 'refunded'
            .yk-card(style='border-color: rgba(231,76,60,0.3); background: rgba(231,76,60,0.01);')
              div(style='padding: 2rem; border-bottom: 1px solid rgba(231,76,60,0.1);')
                h4(style='color: var(--yk-red); font-family: var(--yk-font-heading); font-size: 1.6rem; font-weight: 700; margin: 0;') Danger Zone
              div(style='padding: 2rem; display: flex; gap: 1.2rem; flex-wrap: wrap;')
                button.btn#cancelBookingBtn(data-booking-id=`${booking._id}` style='flex: 1; background: var(--yk-red); color: #fff; border: none; font-size: 1.25rem; padding: 1.2rem;') Cancel Booking
                if booking.paid
                  button.btn#refundBookingBtn(data-booking-id=`${booking._id}` style='flex: 1; background: var(--yk-amber); color: #fff; border: none; font-size: 1.25rem; padding: 1.2rem;') Process Refund

      //- Back link (Tabs UI)
      .yk-tabs(style='margin-top: 4rem;')
        a.yk-tab(href='/admin/bookings') ← Back to Bookings
        a.yk-tab(href='/admin') ← Dashboard

  //- Admin action handlers
  script.
    // Helper
    async function adminAction(url, method, body, btn, successMsg) {
      const original = btn.textContent;
      btn.textContent = 'Processing...';
      btn.disabled = true;
      try {
        const res = await fetch(url, {
          method,
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || 'Action failed');
        showAlert('success', successMsg);
        window.location.reload();
      } catch(err) {
        showAlert('error', `Error: ${err.message}`);
        btn.textContent = original;
        btn.disabled = false;
      }
    }

    // Update status
    const statusBtn = document.getElementById('updateStatusBtn');
    if (statusBtn) {
      statusBtn.addEventListener('click', function() {
        const status = document.getElementById('statusSelect').value;
        adminAction(`/api/v1/bookings/${this.dataset.bookingId}/status`, 'PATCH', { status }, this, 'Status updated!');
      });
    }

    // Assign guide
    const guideBtn = document.getElementById('assignGuideBtn');
    if (guideBtn) {
      guideBtn.addEventListener('click', function() {
        const guideId = document.getElementById('guideSelect').value;
        if (!guideId) { showAlert('error', 'Please select a guide'); return; }
        adminAction(`/api/v1/bookings/${this.dataset.bookingId}/assign-guide`, 'PATCH', { guideId }, this, 'Guide assigned!');
      });
    }

    // Update details
    const detailsBtn = document.getElementById('updateDetailsBtn');
    if (detailsBtn) {
      detailsBtn.addEventListener('click', function() {
        const body = {
          pickupLocation: document.getElementById('pickupInput').value,
          tripInstructions: document.getElementById('instructionsInput').value,
          adminNotes: document.getElementById('notesInput').value
        };
        adminAction(`/api/v1/bookings/${this.dataset.bookingId}/details`, 'PATCH', body, this, 'Details saved!');
      });
    }

    // Cancel
    const cancelBtn = document.getElementById('cancelBookingBtn');
    if (cancelBtn) {
      cancelBtn.addEventListener('click', function() {
        if (!confirm('Cancel this booking?')) return;
        const reason = prompt('Cancellation reason:') || 'Cancelled by admin';
        adminAction(`/api/v1/bookings/${this.dataset.bookingId}/cancel`, 'POST', { reason }, this, 'Booking cancelled!');
      });
    }

    // Refund
    const refundBtn = document.getElementById('refundBookingBtn');
    if (refundBtn) {
      refundBtn.addEventListener('click', function() {
        if (!confirm('Process refund for this booking?')) return;
        adminAction(`/api/v1/bookings/${this.dataset.bookingId}/refund`, 'POST', {}, this, 'Refund processed!');
      });
    }
