doctype html
html
  head
    block head
      meta(charset='UTF-8')
      meta(name='viewport' content='width=device-width, initial-scale=1.0')
      link(rel='stylesheet' href='/css/style.css')
      link(rel='shortcut icon' type='image/png' href='/img/favicon.png')
      link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&family=Cabin:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Lato:wght@300;300i;700&display=swap')
      title YatraKaro | #{title}
      style.
        .alert {
          position: fixed;
          top: 12rem;
          left: 50%;
          transform: translate(-50%, 0);
          z-index: 999999999;
          display: flex;
          align-items: center;
          gap: 1.5rem;
          padding: 1.6rem 3rem;
          box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.25);
          font-family: 'Inter', 'Manrope', sans-serif;
          font-size: 1.5rem;
          font-weight: 500;
          line-height: 1.5;
          width: 90%;
          max-width: 65rem;
          border-radius: 8px;
          animation: alertSlideIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
          transition: all 0.3s ease;
        }
        .alert--success {
          background-color: #0b2512;
          border: 1px solid #1e7e34;
          color: #a4ecc1;
        }
        .alert--error {
          background-color: #261502;
          border: 1px solid #c97d02;
          color: #ffd899;
        }
        .alert__message {
          flex: 1;
          text-align: center;
        }
        .alert__close {
          background: none;
          border: none;
          color: inherit;
          font-size: 2.2rem;
          cursor: pointer;
          padding: 0;
          display: flex;
          align-items: center;
          justify-content: center;
          line-height: 1;
          opacity: 0.7;
          transition: opacity 0.2s;
        }
        .alert__close:hover {
          opacity: 1;
        }
        @keyframes alertSlideIn {
          0% {
            opacity: 0;
            transform: translate(-50%, -4rem);
          }
          100% {
            opacity: 1;
            transform: translate(-50%, 0);
          }
        }
        @media (max-width: 680px) {
          .alert {
            max-width: 92%;
          }
        }
  
  body
    // HEADER
    include _header
        
    // CONTENT
    block content
      h1 This is a placeholder heading
      
    // FOOTER
    include _footer
    
    // ✅ Stripe script MUST load before your own JS
    script(src='https://js.stripe.com/v3/')
    // GSAP + ScrollTrigger for advanced animations
    script(src='https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js')
    script(src='/js/bundle.js')
    script(src='/js/landing.js')
    script.
      (function() {
        window.hideAlert = function() {
          const el = document.querySelector('.alert');
          if (el) {
            el.style.opacity = '0';
            el.style.transform = 'translate(-50%, -4rem)';
            setTimeout(() => el.remove(), 300);
          }
        };
        
        window.showAlert = function(type, msg) {
          window.hideAlert();
          
          let displayMsg = msg;
          
          if (type === 'error') {
            if (msg && (msg.includes('idempotency') || msg.includes('idempotent') || msg.includes('checkout_') || msg.includes('Keys for') || msg.includes('duplicate') || msg.includes('parameter') || msg.includes('same parameter'))) {
              displayMsg = 'Please wait 5 minutes before booking this tour again';
            }
          }
          
          const alertDiv = document.createElement('div');
          alertDiv.className = `alert alert--${type}`;
          
          const msgDiv = document.createElement('div');
          msgDiv.className = 'alert__message';
          msgDiv.textContent = displayMsg;
          
          const closeBtn = document.createElement('button');
          closeBtn.className = 'alert__close';
          closeBtn.textContent = '×';
          closeBtn.onclick = window.hideAlert;
          
          alertDiv.appendChild(msgDiv);
          alertDiv.appendChild(closeBtn);
          
          document.querySelector('body').appendChild(alertDiv);
          
          if (window.alertTimeout) clearTimeout(window.alertTimeout);
          window.alertTimeout = setTimeout(window.hideAlert, 7000);
        };
        
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape') window.hideAlert();
        });
      })();
