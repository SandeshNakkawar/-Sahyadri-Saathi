extends base
include _reviewCard

block append head
   script(src='https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.js')
   link(href='https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.css' rel='stylesheet')
  
mixin overviewBox(label, text, icon)
  .overview-box__detail
    svg.overview-box__icon
      use(xlink:href=`/img/icons.svg#icon-${icon}`)
    span.overview-box__label= label
    span.overview-box__text= text

block content
  section.section-header
    .header__hero
      .header__hero-overlay &nbsp;
      img.header__hero-img(src=`/img/tours/${tour.imageCover}`, alt=`${tour.name}`)

    .heading-box
      h1.heading-primary
        span= `${tour.name} tour`
      .heading-box__group
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-clock')
          span.heading-box__text= `${tour.duration} days`
        .heading-box__detail
          svg.heading-box__icon
            use(xlink:href='/img/icons.svg#icon-map-pin')
          span.heading-box__text= tour.startLocation.description

  section.section-description
    .overview-box
      div
        .overview-box__group
          h2.heading-secondary.ma-bt-lg Quick facts

          - let date = 'Not available';
          - if (tour.startDates && tour.startDates.length)
            - const nextDate = tour.startDates.find(sd => new Date(sd.date) > new Date() && !sd.soldOut)
            - if (nextDate)
              - date = new Date(nextDate.date).toLocaleString('en-us', { month: 'long', year: 'numeric' })
          +overviewBox('Next date', date, 'calendar')
          +overviewBox('Difficulty', tour.difficulty, 'trending-up')
          +overviewBox('Participants', `${tour.maxGroupSize} people`, 'user')
          +overviewBox('Rating', `${tour.ratingsAverage} / 5`, 'star')

        .overview-box__group
          h2.heading-secondary.ma-bt-lg Your tour guides
          - if (tour.guides && tour.guides.length)
            each guide in tour.guides
              .overview-box__detail
                img.overview-box__img(src=`/img/users/${guide.photo}`, alt=`${guide.name}`)

                - if (guide.role === 'lead-guide')
                  span.overview-box__label Lead guide
                - if (guide.role === 'guide')
                  span.overview-box__label Tour guide
                span.overview-box__text= guide.name
          - else
            .overview-box__detail
              span.overview-box__text No guides available

    .description-box
      h2.heading-secondary.ma-bt-lg= `About ${tour.name} tour`
      - const parapraphs = tour.description.split('\n');
      each p in parapraphs
        p.description__text= p
  - if (tour.images && tour.images.length)
    section.section-pictures
      each img, i in tour.images
        .picture-box
          img.picture-box__img(src=`/img/tours/${img}`, alt=`The Park Camper Tour ${i + 1}`, class=`picture-box__img--${i + 1}`)
  - else
    section.section-pictures
      p.text-center No pictures available for this tour.
  section.section-map
    #map(data-locations=`${JSON.stringify(tour.locations)}`)

  section.section-reviews
    .reviews
      each review in tour.reviews
        +reviewCard(review)

  section.section-cta
    .cta
      .cta__img.cta__img--logo
        img(src='/img/logo-white.png', alt='YatraKaro logo')
      if tour.images && tour.images.length >= 3
        img.cta__img.cta__img--1(src=`/img/tours/${tour.images[1]}`, alt='Tour picture')
        img.cta__img.cta__img--2(src=`/img/tours/${tour.images[2]}`, alt='Tour picture')
      .cta__content
        h2.heading-secondary What are you waiting for?
        p.cta__text= `${tour.duration} days. 1 adventure. Infinite memories. Make it yours today!`

        if user
          //- Date & Guest Selection
          - const dates = availableDates || []
          if dates.length > 0
            .booking-form(style='margin-top: 2rem; text-align: left;')
              .booking-form__group(style='margin-bottom: 1.2rem;')
                label.booking-form__label(for='startDate' style='display: block; font-size: 1.4rem; font-weight: 600; margin-bottom: 0.5rem; color: #55c57a;') Select Date
                select#startDate.booking-form__select(data-tour-price=`${tour.price}` style='width: 100%; padding: 1rem 1.2rem; border: 2px solid #55c57a; border-radius: 8px; font-size: 1.4rem; background: #fff; cursor: pointer;')
                  option(value='' disabled selected) Choose a date...
                  each sd in dates
                    option(value=`${sd._id}` data-price=`${sd.price || tour.price}` data-seats=`${sd.availableSeats}`)
                      | #{new Date(sd.date).toLocaleDateString('en-IN', { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' })} — ₹#{(sd.price || tour.price).toLocaleString('en-IN')}/person (#{sd.availableSeats} seats left)

              .booking-form__group(style='margin-bottom: 1.2rem;')
                label.booking-form__label(for='guests' style='display: block; font-size: 1.4rem; font-weight: 600; margin-bottom: 0.5rem; color: #55c57a;') Number of Guests
                select#guests.booking-form__select(style='width: 100%; padding: 1rem 1.2rem; border: 2px solid #55c57a; border-radius: 8px; font-size: 1.4rem; background: #fff; cursor: pointer;')
                  - for (let i = 1; i <= Math.min(tour.maxGroupSize, 10); i++)
                    option(value=`${i}`)= `${i} guest${i > 1 ? 's' : ''}`

              .booking-form__total(style='padding: 1.2rem; background: linear-gradient(135deg, #55c57a22, #28b48722); border-radius: 8px; margin-bottom: 1.5rem; text-align: center;')
                span(style='font-size: 1.4rem; color: #777;') Total:
                span#totalPrice(style='font-size: 2rem; font-weight: 700; color: #28b487; margin-left: 0.8rem;') ₹#{tour.price.toLocaleString('en-IN')}

              button.btn.btn--green.span-all-rows#book-tour(data-tour-id=`${tour.id}`) Book Now!
          else
            p.cta__text(style='color: #ff7730; font-weight: 600;') No dates available for this tour right now.
        else
          a.btn.btn--green.span-all-rows(href='/login') Log in to book tour

  // ✅ Inline booking handler with date/guest selection
  script.
    (function(){
      // Price calculation
      const startDateEl = document.getElementById('startDate');
      const guestsEl = document.getElementById('guests');
      const totalPriceEl = document.getElementById('totalPrice');

      function updateTotal() {
        if (!startDateEl || !guestsEl || !totalPriceEl) return;
        const selectedOption = startDateEl.options[startDateEl.selectedIndex];
        const price = selectedOption && selectedOption.dataset.price
          ? parseFloat(selectedOption.dataset.price)
          : parseFloat(startDateEl.dataset.tourPrice) || 0;
        const guests = parseInt(guestsEl.value, 10) || 1;
        totalPriceEl.textContent = '₹' + (price * guests).toLocaleString('en-IN');
      }

      if (startDateEl) startDateEl.addEventListener('change', updateTotal);
      if (guestsEl) guestsEl.addEventListener('change', updateTotal);

      // Booking handler
      const btn = document.getElementById('book-tour');
      if (!btn) return;

      let isProcessing = false;

      btn.addEventListener('click', async function(e){
        if (isProcessing) return;

        // Validate date selection
        if (startDateEl && !startDateEl.value) {
          showAlert('error', 'Please select a tour date');
          return;
        }

        let timeoutId;

        try {
          e.preventDefault();
          isProcessing = true;
          const originalText = e.target.textContent;
          e.target.textContent = 'Processing...';
          e.target.disabled = true;
          e.target.style.cursor = 'not-allowed';

          const tourId = e.target.dataset.tourId;
          const startDateId = startDateEl ? startDateEl.value : '';
          const guests = guestsEl ? guestsEl.value : '1';

          timeoutId = setTimeout(() => {
            if (isProcessing) {
              e.target.textContent = originalText;
              e.target.disabled = false;
              e.target.style.cursor = 'pointer';
              isProcessing = false;
              showAlert('error', 'Request timed out. Please try again.');
            }
          }, 30000);

          const res = await fetch(`/api/v1/bookings/checkout-session/${tourId}`, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ startDateId, guests })
          });
          const data = await res.json();

          clearTimeout(timeoutId);

          if (!res.ok) {
            if (res.status === 409) {
              showAlert('error', data.message || 'You have a recent booking for this tour.');
              e.target.textContent = originalText;
              e.target.disabled = false;
              e.target.style.cursor = 'pointer';
              isProcessing = false;
              return;
            }
            throw new Error(data.message || `Failed to create checkout session (HTTP ${res.status})`);
          }

          if (!data.session) throw new Error('No session data received');

          if (typeof Stripe === 'undefined') {
            throw new Error('Stripe.js failed to load. Please refresh and try again.');
          }

          const stripe = Stripe('#{process.env.STRIPE_PUBLISHABLE_KEY}');
          await stripe.redirectToCheckout({ sessionId: data.session.id });

          clearTimeout(timeoutId);
          e.target.textContent = originalText;
          e.target.disabled = false;
          e.target.style.cursor = 'pointer';
          isProcessing = false;
        } catch(err) {
          console.error(err);
          if (timeoutId) clearTimeout(timeoutId);
          showAlert('error', `Booking failed: ${err.message}`);
          e.target.textContent = 'Book Now!';
          e.target.disabled = false;
          e.target.style.cursor = 'pointer';
          isProcessing = false;
        }
      });
    })();

